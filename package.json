{
  "name": "@clovrix/sdk",
  "version": "1.0.2",
  "description": "Official Node.js/TypeScript SDK for the Clovrix Public API",
  "license": "MIT",
  "homepage": "https://github.com/clovrix/node-sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clovrix/node-sdk.git"
  },
  "keywords": [
    "clovrix",
    "secrets",
    "config",
    "environment-variables",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
